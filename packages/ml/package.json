{
  "name": "@warpvector/ml",
  "version": "0.6.1",
  "description": "Lightweight non-linear and online learning adapters for edge inference",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean --tsconfig tsconfig.build.json",
    "test": "bun test"
  },
  "keywords": [
    "vector",
    "mlp",
    "whitening",
    "pca",
    "edge"
  ],
  "author": "Daiki Moritake",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/daiki-moritake/warpvector.git",
    "directory": "packages/ml"
  },
  "homepage": "https://github.com/daiki-moritake/warpvector#readme",
  "bugs": {
    "url": "https://github.com/daiki-moritake/warpvector/issues"
  },
  "dependencies": {
    "@warpvector/core": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
