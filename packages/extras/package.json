{
  "name": "@warpvector/extras",
  "version": "0.1.5",
  "description": "Extended adapters: ColBERT, Quantization, VSA, Hybrid Search for WarpVector",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean --tsconfig tsconfig.build.json",
    "test": "bun test"
  },
  "keywords": [
    "vector",
    "colbert",
    "quantization",
    "vsa",
    "hybrid-search"
  ],
  "author": "Daiki Moritake",
  "license": "MIT",
  "dependencies": {
    "@warpvector/core": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
