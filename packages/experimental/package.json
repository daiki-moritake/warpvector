{
  "name": "@warpvector/experimental",
  "version": "0.9.0",
  "description": "(DEPRECATED) Use @warpvector/extras, @warpvector/rerank, or warpvector directly. This package will be removed in v1.0.0.",
  "deprecated": "This package is deprecated. Import from @warpvector/extras, @warpvector/rerank, or warpvector directly.",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean --tsconfig tsconfig.build.json",
    "test": "bun test",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "vector",
    "experimental",
    "colbert",
    "vsa",
    "anomaly-detection"
  ],
  "author": "Daiki Moritake",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/daiki-moritake/warpvector.git",
    "directory": "packages/experimental"
  },
  "homepage": "https://github.com/daiki-moritake/warpvector#readme",
  "bugs": {
    "url": "https://github.com/daiki-moritake/warpvector/issues"
  },
  "dependencies": {
    "@warpvector/core": "workspace:*",
    "@warpvector/extras": "workspace:*",
    "@warpvector/rerank": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
