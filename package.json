{
  "name": "warpvector",
  "version": "0.3.1",
  "description": "Zero-dependency TypeScript middleware for dynamic vector space transformation. Warp embeddings at runtime with WASM-accelerated affine transforms, quantization, online learning, and ColBERT — no retraining needed.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./prisma": {
      "types": "./dist/prisma.d.ts",
      "import": "./dist/prisma.mjs",
      "require": "./dist/prisma.js"
    },
    "./langchain": {
      "types": "./dist/langchain.d.ts",
      "import": "./dist/langchain.mjs",
      "require": "./dist/langchain.js"
    }
  },
  "files": [
    "dist"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "sync:versions": "bun run scripts/sync-versions.ts",
    "build:wasm": "bun run scripts/build-wasm.ts",
    "build:packages": "bun run sync:versions && bun run build:wasm && cd packages/core && bun run build && cd ../ml && bun run build && cd ../extras && bun run build && cd ../prisma && bun run build && cd ../langchain && bun run build && cd ../create-warpvector-app && bun run build",
    "build": "bun run build:packages && tsup",
    "test": "bun run build:wasm && bun test",
    "bench": "bun run build:wasm && bun run benchmarks/run.ts",
    "prepublishOnly": "bun run build && node -e \"const p=require('./package.json'); const deps=Object.values(p.dependencies||{}); if(deps.some(v=>v.includes('workspace:'))) { console.error('ERROR: workspace: protocol found in dependencies'); process.exit(1); }\"",
    "format": "prettier --write \"src/**/*.ts\" \"packages/*/src/**/*.ts\" \"packages/*/tests/**/*.ts\" \"examples/**/*.ts\""
  },
  "keywords": [
    "vector",
    "vector-search",
    "vector-database",
    "embeddings",
    "affine-transformation",
    "rag",
    "retrieval-augmented-generation",
    "ai",
    "search",
    "middleware",
    "wasm",
    "webassembly",
    "quantization",
    "online-learning",
    "edge-computing",
    "colbert",
    "reranking",
    "langchain",
    "prisma",
    "pgvector",
    "typescript",
    "zero-dependency",
    "cloudflare-workers"
  ],
  "author": "Daiki Moritake",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/daiki-moritake/warpvector.git"
  },
  "devDependencies": {
    "@langchain/core": "^1.1.49",
    "@prisma/client": "^7.8.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^20.0.0",
    "assemblyscript": "^0.28.19",
    "prettier": "^3.0.0",
    "sql-template-tag": "^5.2.1",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@prisma/client": "^5.0.0 || ^6.0.0 || ^7.0.0",
    "sql-template-tag": "^5.0.0",
    "@langchain/core": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@prisma/client": {
      "optional": true
    },
    "sql-template-tag": {
      "optional": true
    },
    "@langchain/core": {
      "optional": true
    }
  }
}
